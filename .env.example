# 이 파일을 .env로 복사한 뒤 실제 값을 채우세요: cp .env.example .env
# 실제 키는 .env에만 두고, 이 템플릿(.env.example)에는 절대 입력하지 마세요.

# ── 필수 ──────────────────────────────────────────────
# Claude API 키 (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# ── 선택 ──────────────────────────────────────────────
# NewsAPI 키 (RSS만 쓸 경우 비워둬도 됨)
NEWSAPI_KEY=

# 모델 오버라이드 (기본값: 아래)
# MODEL_FAST=claude-haiku-4-5
# MODEL_SMART=claude-sonnet-4-6

# 거시 리스크 임계값 (VIX)
# VIX_MID_THRESHOLD=20
# VIX_HIGH_THRESHOLD=30

# 스크리너 필터
# MIN_MARKET_CAP=1000000000
# MIN_AVG_VOLUME=500000
# HOT_SECTOR_COUNT=3
# MAX_CANDIDATES_PER_SECTOR=5

# 관심 섹터 (콤마 구분) — 뉴스 핫섹터와 무관하게 항상 분석 대상에 포함.
#   가능 값: Technology, Semiconductors, Communication Services, Healthcare,
#            Financials, Energy, Consumer Discretionary, Consumer Staples,
#            Industrials, Materials, Utilities, Real Estate
# PREFERRED_SECTORS=Energy,Industrials

# 포트폴리오 과대비중 임계값 (0~1)
# PORTFOLIO_OVERWEIGHT_THRESHOLD=0.30

# 뉴스 수집
# NEWS_MAX_AGE_DAYS=3
# NEWS_MAX_ARTICLES=100

# 스케줄 (매일 실행 시각)
# SCHEDULE_HOUR=7
# SCHEDULE_MINUTE=0
# TIMEZONE=Asia/Seoul

# ── 알림 발송 ─────────────────────────────────────────
# 채널 선택: telegram | gmail | none (기본 none)
# NOTIFICATION_CHANNEL=none

# 텔레그램 사용 시 (@BotFather로 봇 생성 후 토큰/챗ID 입력)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Gmail 사용 시 (2단계 인증 후 16자리 앱 비밀번호 사용)
# GMAIL_SENDER=
# GMAIL_PASSWORD=
# GMAIL_RECIPIENT=
